# Database (PostgreSQL for production, SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./eve_dev.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/eve

# Redis (for session store & caching)
REDIS_URL=redis://localhost:6379/0

# Wallet encryption key (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
WALLET_ENCRYPTION_KEY=

# Solana RPC (use a paid provider for production: Helius, QuickNode, etc.)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Launcher service (Next.js sidecar that wraps @pump-fun/pump-sdk)
LAUNCHER_SERVICE_URL=http://localhost:3000

# Metadata endpoint (where pump.fun fetches token metadata from)
METADATA_BASE_URL=http://localhost:8000

# X / Twitter OAuth 2.0
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8000/v1/auth/x/callback

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168

# Trading thresholds
EXCESS_PROFIT_THRESHOLD_SOL=0.05
MAX_BUYBACK_SOL=1.0
RESERVE_SOL=0.01
